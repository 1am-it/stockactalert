# Supabase - get from supabase.com dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Quiver Quant - get from quiverquant.com
QUIVER_API_KEY=your_quiver_api_key

# Unusual Whales - get from unusualwhales.com
UNUSUAL_WHALES_API_KEY=your_unusual_whales_key

# Telegram Bot - get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Stripe - get from dashboard.stripe.com
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Resend - get from resend.com
RESEND_API_KEY=your_resend_api_key

# Vercel Cron protection
CRON_SECRET=make_up_a_long_random_string

# Congress.gov - get from https://api.congress.gov/sign-up/
# Used by scripts/fetch-congress.mjs (1AM-67) to refresh src/data/congress.json
CONGRESS_GOV_API_KEY=your_congress_gov_api_key

# Firebase Cloud Messaging - get from console.firebase.google.com
FIREBASE_SERVER_KEY=your_firebase_server_key